# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=flight-telemetry-v1
PRODUCER_CLIENT_ID=opensky-producer

# ── OpenSky (leave blank to use anonymous — lower rate limit) ──────────────────
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
OPENSKY_POLL_SECONDS=10

# Bounding box (CONUS defaults below)
OPENSKY_BBOX_LAMIN=24.0
OPENSKY_BBOX_LAMAX=50.0
OPENSKY_BBOX_LOMIN=-125.0
OPENSKY_BBOX_LOMAX=-66.0

# ── Deduplication ─────────────────────────────────────────────────────────────
ENABLE_DEDUPE=true
DEDUPE_TTL_SECONDS=120

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=flight_data
POSTGRES_USER=nickbui
POSTGRES_PASSWORD=dummy

# ── Spark ─────────────────────────────────────────────────────────────────────
SPARK_CHECKPOINT_DIR=./spark-checkpoints

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PORT=8501

# ── Mode: simulator | opensky ─────────────────────────────────────────────────
MODE=simulator
